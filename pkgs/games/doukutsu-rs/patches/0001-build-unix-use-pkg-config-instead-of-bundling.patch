From e5b70244dff645b9978337d6079e84a3082efb50 Mon Sep 17 00:00:00 2001
From: "tsrk." <tsrk@tsrk.me>
Date: Sun, 15 Mar 2026 02:15:23 +0100
Subject: [PATCH] build(unix): use pkg-config instead of bundling

Signed-off-by: tsrk. <tsrk@tsrk.me>
---
 Cargo.lock |  1 +
 Cargo.toml | 10 ++++++++--
 2 files changed, 9 insertions(+), 2 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
index 72a0100..a47f948 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -1987,6 +1987,7 @@ dependencies = [
  "cfg-if 1.0.4",
  "cmake",
  "libc",
+ "pkg-config",
  "version-compare",
 ]
 
diff --git a/Cargo.toml b/Cargo.toml
index 9c88c67..4ad6ae1 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -79,8 +79,6 @@ num-derive = "0.3"
 num-traits = "0.2"
 paste = "1.0"
 pelite = { version = ">=0.9.2", default-features = false, features = ["std"] }
-sdl2 = { git = "https://github.com/doukutsu-rs/rust-sdl2.git", rev = "244ae85833cff4f97ab4b58331741be20e422bd7", optional = true, features = ["unsafe_textures", "bundled", "static-link"] }
-sdl2-sys = { git = "https://github.com/doukutsu-rs/rust-sdl2.git", rev = "244ae85833cff4f97ab4b58331741be20e422bd7", optional = true, features = ["bundled", "static-link"] }
 rc-box = "1.2.0"
 serde = { version = "1", features = ["derive"] }
 serde_derive = "1"
@@ -115,3 +113,11 @@ jni = "0.20"
 [target.'cfg(target_os = "horizon")'.dependencies]
 #deko3d = { path = "./3rdparty/deko3d" }
 deko3d = { git = "https://github.com/doukutsu-rs/deko3d-rs", branch = "master" }
+
+[target.'cfg(not(unix))'.dependencies]
+sdl2 = { git = "https://github.com/doukutsu-rs/rust-sdl2.git", rev = "244ae85833cff4f97ab4b58331741be20e422bd7", optional = true, features = ["unsafe_textures", "bundled", "static-link"] }
+sdl2-sys = { git = "https://github.com/doukutsu-rs/rust-sdl2.git", rev = "244ae85833cff4f97ab4b58331741be20e422bd7", optional = true, features = ["bundled", "static-link"] }
+
+[target.'cfg(unix)'.dependencies]
+sdl2 = { git = "https://github.com/doukutsu-rs/rust-sdl2.git", rev = "244ae85833cff4f97ab4b58331741be20e422bd7", optional = true, features = ["unsafe_textures", "use-pkgconfig", "static-link"] }
+sdl2-sys = { git = "https://github.com/doukutsu-rs/rust-sdl2.git", rev = "244ae85833cff4f97ab4b58331741be20e422bd7", optional = true, features = ["use-pkgconfig", "static-link"] }
-- 
2.51.2

